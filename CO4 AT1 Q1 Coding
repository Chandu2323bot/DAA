# DAA
#include <iostream>
#include <climits>
using namespace std;

int main() {
    int n = 5;
    int g[5][5] = {
        {0,2,0,6,0},
        {2,0,3,8,5},
        {0,3,0,0,7},
        {6,8,0,0,9},
        {0,5,7,9,0}
    };

    int key[5], parent[5];
    bool mst[5];

    for(int i=0;i<n;i++) {
        key[i] = INT_MAX;
        mst[i] = false;
    }

    key[0] = 0;
    parent[0] = -1;

    for(int count=0; count<n-1; count++) {
        int min = INT_MAX, u;

        for(int v=0; v<n; v++)
            if(!mst[v] && key[v] < min)
                min = key[v], u = v;

        mst[u] = true;

        for(int v=0; v<n; v++)
            if(g[u][v] && !mst[v] && g[u][v] < key[v])
                parent[v] = u, key[v] = g[u][v];
    }

    cout << "MST Edges:\n";
    for(int i=1; i<n; i++)
        cout << parent[i] << " - " << i
             << " : " << g[i][parent[i]] << endl;

    return 0
Output :
Edge    Weight
0 - 1   2
1 - 2   3
0 - 3   6
1 - 4   5;
}
